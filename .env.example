# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=smr_psd
POSTGRES_USER=smr_user
POSTGRES_PASSWORD=change_me_strong_password

# Async connection string (собирается в config.py)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── MinIO (S3-совместимое хранилище файлов) ───────────────────────
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret
MINIO_BUCKET_DRAWINGS=drawings
MINIO_BUCKET_ASBUILT=asbuilt
MINIO_BUCKET_CERTIFICATES=certificates
MINIO_BUCKET_REPORTS=reports

# ── Backend ───────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
LOG_LEVEL=info

# ── Frontend ──────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000/api/v1
